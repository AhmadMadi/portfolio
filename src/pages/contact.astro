---
import FlowLayout from "../layouts/FlowLayout.astro";
---

<FlowLayout
  title="Contact – Ahmad Madi"
  step={5}
  total={5}
  backHref="/skills"
  nextHref="/"
>
  <section class="space-y-8">
    <header class="space-y-4">
      <p class="eyebrow">04 — Contact</p>
      <h1
        class="font-display text-4xl font-medium tracking-tight text-paper-100"
      >
        Say hello.
      </h1>
      <p class="max-w-2xl leading-relaxed text-paper-400">
        I'm open to remote work and happy to relocate for the right team. Email
        gets to me fastest, but LinkedIn works too.
      </p>
    </header>

    <div class="grid gap-3 sm:grid-cols-2">
      <a
        href="mailto:ahmadsamimadi@gmail.com"
        class="group flex items-center gap-4 rounded-xl border border-ink-800 p-4 transition-colors duration-300 hover:border-ink-700 hover:bg-ink-900"
      >
        <span
          class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-ink-850 text-paper-300 transition-colors duration-300 group-hover:text-accent"
        >
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <rect
              x="1.75"
              y="3.25"
              width="12.5"
              height="9.5"
              rx="1.5"
              stroke="currentColor"
              stroke-width="1.5"></rect>
            <path
              d="m2.5 4.5 5.5 4 5.5-4"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </span>
        <span class="min-w-0">
          <span class="block text-sm font-medium text-paper-100">Email</span>
          <span class="block truncate font-mono text-[0.72rem] text-paper-500"
            >ahmadsamimadi@gmail.com</span
          >
        </span>
      </a>

      <a
        href="https://www.linkedin.com/in/ahmad-s-madi/"
        target="_blank"
        rel="noreferrer"
        class="group flex items-center gap-4 rounded-xl border border-ink-800 p-4 transition-colors duration-300 hover:border-ink-700 hover:bg-ink-900"
      >
        <span
          class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-ink-850 text-paper-300 transition-colors duration-300 group-hover:text-accent"
        >
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path
              d="M3.5 6H1.5v8h2V6ZM2.5 2a1.25 1.25 0 1 0 0 2.5 1.25 1.25 0 0 0 0-2.5ZM14.5 9.3c0-2.1-1.1-3.1-2.6-3.1-1.2 0-1.8.66-2.1 1.13V6H7.7c.03.56 0 8 0 8h2.1V9.6c0-.19.01-.38.07-.51.15-.38.5-.77 1.08-.77.76 0 1.07.58 1.07 1.43V14h2.1l.02-4.7Z"
            ></path>
          </svg>
        </span>
        <span>
          <span class="block text-sm font-medium text-paper-100">LinkedIn</span>
          <span class="block font-mono text-[0.72rem] text-paper-500">ahmad-s-madi</span>
        </span>
      </a>

      <a
        href="https://github.com/AhmadMadi"
        target="_blank"
        rel="noreferrer"
        class="group flex items-center gap-4 rounded-xl border border-ink-800 p-4 transition-colors duration-300 hover:border-ink-700 hover:bg-ink-900"
      >
        <span
          class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-ink-850 text-paper-300 transition-colors duration-300 group-hover:text-accent"
        >
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path
              d="M8 .8a7.2 7.2 0 0 0-2.28 14.03c.36.07.49-.16.49-.35v-1.2c-2 .43-2.43-.97-2.43-.97-.33-.83-.8-1.05-.8-1.05-.65-.45.05-.44.05-.44.72.05 1.1.74 1.1.74.64 1.1 1.68.78 2.09.6.06-.47.25-.79.45-.97-1.6-.18-3.28-.8-3.28-3.56 0-.79.28-1.43.74-1.93-.07-.18-.32-.92.07-1.9 0 0 .6-.2 1.98.73a6.9 6.9 0 0 1 3.6 0c1.37-.93 1.97-.73 1.97-.73.4.98.15 1.72.08 1.9.46.5.73 1.14.73 1.93 0 2.77-1.68 3.38-3.28 3.56.26.22.49.66.49 1.33v1.97c0 .19.13.42.5.35A7.2 7.2 0 0 0 8 .8Z"
            ></path>
          </svg>
        </span>
        <span>
          <span class="block text-sm font-medium text-paper-100">GitHub</span>
          <span class="block font-mono text-[0.72rem] text-paper-500">AhmadMadi</span>
        </span>
      </a>

      <a
        href="/Ahmad Madi - Resume.pdf"
        class="group flex items-center gap-4 rounded-xl border border-ink-800 p-4 transition-colors duration-300 hover:border-ink-700 hover:bg-ink-900"
      >
        <span
          class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-ink-850 text-paper-300 transition-colors duration-300 group-hover:text-accent"
        >
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path
              d="M8 1.5v6m0 0L5.5 5M8 7.5 10.5 5M3 10.5v2.5A1.5 1.5 0 0 0 4.5 14.5h7a1.5 1.5 0 0 0 1.5-1.5v-2.5"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </span>
        <span>
          <span class="block text-sm font-medium text-paper-100">Résumé</span>
          <span class="block font-mono text-[0.72rem] text-paper-500">PDF · download</span>
        </span>
      </a>
    </div>

    <p class="rule-top pt-6 text-sm text-paper-500">
      Based in Beirut. Working remotely, and open to moving for the right role.
    </p>
  </section>
</FlowLayout>
