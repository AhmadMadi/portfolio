---
import FlowLayout from "../layouts/FlowLayout.astro";
---

<FlowLayout
  title="Ahmad Madi – Full Stack Software Engineer"
  step={1}
  total={5}
  nextHref="/about"
>
  <section class="space-y-10">
    <div class="space-y-6">
      <p class="eyebrow">Ahmad Madi</p>

      <h1
        class="font-display text-[2.6rem] font-medium leading-[1.05] tracking-tight text-paper-100 sm:text-6xl"
      >
        Full Stack<br />
        <span class="text-paper-400">Software Engineer</span>
      </h1>

      <p class="max-w-xl text-[1.05rem] leading-relaxed text-paper-200">
        I build the backend systems companies quietly run on. The parts users
        never see but can't work without.
      </p>

      <p class="max-w-xl leading-relaxed text-paper-500">
        Most of my work lives on AWS: internal platforms, cloud automation, and
        the analytics a business leans on every day. Lately I've spent a lot of
        it modernizing older systems without taking production down.
      </p>
    </div>

    <div class="flex flex-col gap-3 sm:flex-row">
      <a
        href="/Ahmad Madi - Resume.pdf"
        class="group inline-flex items-center justify-center gap-2 rounded-full bg-paper-100 px-5 py-2.5 text-sm font-medium text-ink-950 transition-colors duration-300 hover:bg-white"
      >
        <svg
          class="h-4 w-4 transition-transform duration-300 group-hover:translate-y-0.5"
          viewBox="0 0 16 16"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M8 2.5v8m0 0L4.5 7M8 10.5 11.5 7M2.5 13.5h11"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        Download résumé
      </a>

      <a
        href="/about"
        class="group inline-flex items-center justify-center gap-2 rounded-full border border-ink-700 px-5 py-2.5 text-sm text-paper-100 transition-colors duration-300 hover:bg-ink-850"
      >
        Get to know me
        <svg
          class="h-4 w-4 text-paper-400 transition-transform duration-300 group-hover:translate-x-0.5"
          viewBox="0 0 16 16"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M3.5 8h9m0 0L9 4.5M12.5 8 9 11.5"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>

    <!-- Facts as an editorial ruled list, not three matching cards -->
    <dl class="grid gap-px overflow-hidden rounded-2xl border border-ink-800 bg-ink-800 sm:grid-cols-3">
      <div class="bg-ink-950 p-5">
        <dt class="text-xs uppercase tracking-wider text-paper-600">Focus</dt>
        <dd class="mt-2 text-sm text-paper-200">
          Backend · Cloud Automation · Reliability
        </dd>
      </div>
      <div class="bg-ink-950 p-5">
        <dt class="text-xs uppercase tracking-wider text-paper-600">
          Core stack
        </dt>
        <dd class="mt-2 text-sm text-paper-200">
          AWS · Node.js · TypeScript · Python
        </dd>
      </div>
      <div class="bg-ink-950 p-5">
        <dt class="text-xs uppercase tracking-wider text-paper-600">
          Currently
        </dt>
        <dd class="mt-2 text-sm text-paper-200">
          Software Engineer III · Washmen (Remote)
        </dd>
      </div>
    </dl>
  </section>
</FlowLayout>
