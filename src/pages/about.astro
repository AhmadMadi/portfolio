---
import FlowLayout from "../layouts/FlowLayout.astro";
---

<FlowLayout
  title="About – Ahmad Madi"
  step={2}
  total={5}
  backHref="/"
  nextHref="/work"
>
  <section class="space-y-8">
    <header class="space-y-4">
      <p class="eyebrow">01 — About</p>
      <h1
        class="font-display text-4xl font-medium tracking-tight text-paper-100"
      >
        Building systems that stay up.
      </h1>
      <p class="max-w-2xl text-[1.05rem] leading-relaxed text-paper-300">
        Senior software engineer with over five years building and operating
        cloud-based systems in production — internal platforms, backend
        services, and the operational tooling teams rely on daily.
      </p>
      <p class="max-w-2xl leading-relaxed text-paper-500">
        My work focuses on designing scalable backend systems, automating
        workflows with cloud-native architectures, and modernizing legacy
        systems without disrupting production.
      </p>
    </header>

    <div class="grid gap-8 sm:grid-cols-2">
      <div class="space-y-3">
        <h2 class="text-sm font-semibold text-paper-200">What I do best</h2>
        <ul class="space-y-2.5 text-sm text-paper-400">
          <li class="flex gap-3">
            <span class="mt-2 h-px w-3 shrink-0 bg-accent"></span>
            Designing scalable backend APIs and services
          </li>
          <li class="flex gap-3">
            <span class="mt-2 h-px w-3 shrink-0 bg-accent"></span>
            Cloud automation with AWS and event-driven systems
          </li>
          <li class="flex gap-3">
            <span class="mt-2 h-px w-3 shrink-0 bg-accent"></span>
            Improving production performance and stability
          </li>
          <li class="flex gap-3">
            <span class="mt-2 h-px w-3 shrink-0 bg-accent"></span>
            Migrating legacy systems to modern stacks
          </li>
        </ul>
      </div>

      <div class="space-y-3">
        <h2 class="text-sm font-semibold text-paper-200">How I work</h2>
        <ul class="space-y-2.5 text-sm text-paper-400">
          <li class="flex gap-3">
            <span class="mt-2 h-px w-3 shrink-0 bg-ink-700"></span>
            Pragmatic and impact-driven
          </li>
          <li class="flex gap-3">
            <span class="mt-2 h-px w-3 shrink-0 bg-ink-700"></span>
            Strong ownership from design to rollout
          </li>
          <li class="flex gap-3">
            <span class="mt-2 h-px w-3 shrink-0 bg-ink-700"></span>
            Clear communication of tradeoffs
          </li>
          <li class="flex gap-3">
            <span class="mt-2 h-px w-3 shrink-0 bg-ink-700"></span>
            Focused on shipping and iterating safely
          </li>
        </ul>
      </div>
    </div>

    <div class="rule-top pt-6">
      <h2 class="text-xs uppercase tracking-wider text-paper-600">Currently</h2>
      <p class="mt-2 max-w-2xl text-sm leading-relaxed text-paper-300">
        Working remotely at Washmen on internal platforms, operational
        analytics, and cloud automation. Also building independent products,
        including MenuDash.
      </p>
    </div>
  </section>
</FlowLayout>
