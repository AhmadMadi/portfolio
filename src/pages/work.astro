---
import FlowLayout from "../layouts/FlowLayout.astro";
---

<FlowLayout
  title="Work – Ahmad Madi"
  step={3}
  total={5}
  backHref="/about"
  nextHref="/skills"
>
  <section class="space-y-8">
    <header class="space-y-4">
      <p class="eyebrow">02 — Work</p>
      <h1
        class="font-display text-4xl font-medium tracking-tight text-paper-100"
      >
        Selected work
      </h1>
      <p class="max-w-2xl leading-relaxed text-paper-400">
        A couple of projects I'm proud of — one from my role at Washmen, and one
        product I built end to end.
      </p>
    </header>

    <div class="divide-y divide-ink-800 border-y border-ink-800">
      <!-- Washmen -->
      <article class="group grid gap-4 py-6 sm:grid-cols-[8rem_1fr]">
        <div class="space-y-1">
          <div class="text-sm font-medium text-paper-200">Washmen</div>
          <div class="text-xs text-paper-600">Internal platform</div>
        </div>
        <div class="space-y-3">
          <h2 class="font-display text-xl font-medium text-paper-100">
            Ops Dashboard
          </h2>
          <p class="max-w-xl text-sm leading-relaxed text-paper-400">
            Modernized operational tooling into a scalable, API-driven system —
            improving maintainability and day-to-day usability while keeping
            production stable throughout the migration.
          </p>
          <div class="flex flex-wrap gap-2 pt-1">
            {
              ["React", "TypeScript", "Backend APIs", "AWS"].map((t) => (
                <span class="rounded-full border border-ink-800 px-2.5 py-0.5 text-xs text-paper-500">
                  {t}
                </span>
              ))
            }
          </div>
        </div>
      </article>

      <!-- MenuDash -->
      <a
        href="https://menudash.io"
        target="_blank"
        rel="noreferrer"
        class="group grid gap-4 py-6 transition-colors duration-300 sm:grid-cols-[8rem_1fr]"
      >
        <div class="space-y-1">
          <div class="text-sm font-medium text-paper-200">MenuDash</div>
          <div class="text-xs text-paper-600">Independent · SaaS</div>
        </div>
        <div class="space-y-3">
          <h2
            class="flex items-center gap-2 font-display text-xl font-medium text-paper-100 transition-colors duration-300 group-hover:text-accent-soft"
          >
            Digital menu platform
            <svg
              class="h-4 w-4 text-paper-500 transition-all duration-300 group-hover:-translate-y-0.5 group-hover:translate-x-0.5 group-hover:text-accent"
              viewBox="0 0 16 16"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M5 11 11 5m0 0H6m5 0v5"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </h2>
          <p class="max-w-xl text-sm leading-relaxed text-paper-400">
            A streamlined platform that helps businesses create, edit, and
            present menus online — with a clean dashboard for items, images, and
            pricing.
          </p>
          <div class="flex flex-wrap gap-2 pt-1">
            {
              ["SaaS", "Dashboard UI", "Menu items", "Pricing"].map((t) => (
                <span class="rounded-full border border-ink-800 px-2.5 py-0.5 text-xs text-paper-500 transition-colors duration-300 group-hover:border-accent/40 group-hover:text-accent-soft">
                  {t}
                </span>
              ))
            }
          </div>
        </div>
      </a>
    </div>
  </section>
</FlowLayout>
