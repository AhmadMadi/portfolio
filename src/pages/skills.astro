---
import FlowLayout from "../layouts/FlowLayout.astro";

const groups = [
  {
    label: "Backend",
    items: ["Node.js", "TypeScript", "Python", "REST APIs", "Microservices", "SQL / NoSQL"],
  },
  {
    label: "Cloud & Reliability",
    items: ["AWS Lambda", "ECS", "S3", "Redshift", "SQS / SNS", "Observability"],
  },
  {
    label: "Frontend",
    items: ["React", "TypeScript", "UI migrations", "Performance"],
  },
  {
    label: "Quality & Delivery",
    items: ["CI/CD", "Testing", "Code review", "Docs", "Agile"],
  },
];
---

<FlowLayout
  title="Skills – Ahmad Madi"
  step={4}
  total={5}
  backHref="/work"
  nextHref="/contact"
>
  <section class="space-y-8">
    <header class="space-y-4">
      <p class="eyebrow">03 — Skills</p>
      <h1
        class="font-display text-4xl font-medium tracking-tight text-paper-100"
      >
        The toolkit
      </h1>
      <p class="max-w-2xl leading-relaxed text-paper-400">
        The tools I actually reach for, not everything I've ever touched.
      </p>
    </header>

    <div class="grid gap-x-10 gap-y-8 sm:grid-cols-2">
      {
        groups.map((g) => (
          <div class="rule-top pt-5">
            <h2 class="text-sm font-semibold text-paper-200">{g.label}</h2>
            <ul class="mt-3 flex flex-wrap gap-2">
              {g.items.map((item) => (
                <li class="rounded-full border border-ink-800 bg-ink-900 px-3 py-1 font-mono text-[0.72rem] text-paper-300">
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="rule-top pt-6">
      <h2 class="font-mono text-[0.7rem] uppercase tracking-wide text-paper-600">
        How I pick
      </h2>
      <p class="mt-2 max-w-2xl text-sm leading-relaxed text-paper-300">
        I'd rather ship something solid today and sharpen it next week than
        chase perfect and ship nothing. Boring, proven tools usually win.
      </p>
    </div>
  </section>
</FlowLayout>
